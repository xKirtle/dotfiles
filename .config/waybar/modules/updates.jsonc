{
  "custom/updates": {
    "format": "  {}",
    "escape": true,
    "return-type": "json",
    "exec": "~/.config/waybar/scripts/updates.sh",
    "interval": 1800,
    "signal": 1,
    "hide-empty-text": true,
    // "on-click": "setsid -f kitty -e bash -lc \"$HOME/.config/waybar/scripts/install-updates.sh\""
    "on-click": "setsid -f kitty -e ~/dotfiles/go-scripts/aur-updates"
  }
}
